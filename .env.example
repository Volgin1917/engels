# ==========================================
# Приложение (Backend)
# ==========================================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Логирование
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==========================================
# База данных (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kgd_crm
DB_USER=postgres
DB_PASSWORD=secret_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==========================================
# Кэш и Очереди (Redis)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# URL для Celery (если используется)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==========================================
# Strapi CMS
# ==========================================
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token_here

# ==========================================
# LLM / AI Сервисы
# ==========================================
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# Альтернативные провайдеры (опционально)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ==========================================
# Безопасность
# ==========================================
SECRET_KEY=super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:1337"]

# ==========================================
# Файловое хранилище (S3-compatible)
# ==========================================
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_REGION=us-east-1

# ==========================================
# Мониторинг (опционально)
# ==========================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false
